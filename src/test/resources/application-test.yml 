spring:
  datasource:
    url: jdbc:h2:mem:mercadox_test;DB_CLOSE_DELAY=-1;MODE=MySQL
    driver-class-name: org.h2.Driver
    username: sa
    password:

  jpa:
    hibernate:
      ddl-auto: create-drop
    database-platform: org.hibernate.dialect.H2Dialect
    show-sql: false

  # Desactiva SendGrid en tests — ningún correo real se envía
  autoconfigure:
    exclude: com.sendgrid.spring.boot.SendGridAutoConfiguration

jwt:
  secret: test-secret-key-for-ci-minimum-32-bytes
  accessTokenExpiration: 9000000

sendgrid:
  api-key: test-key-not-used-in-tests
  from-email: test@test.com
  from-name: MercadoxTest
  support-email: support@test.com

logging:
  level:
    root: WARN
    com.mercadox: DEBUG